# ==================== API Key配置 ====================
# 只需填写你有的API Key，没有的留空即可

# DeepSeek大模型API（可选，用于智能分析）
API_DEEPSEEK=

# ServerChan方糖Key（可选，推送微信）
API_SERVERCHAN=

# Bing搜索API（可选，搜索热点）
API_BING_SEARCH=

# imgflip账号（可选，生成自定义表情包）
API_IMGFLIP_USER=
API_IMGFLIP_PASS=

# ==================== 其他设置 ====================
# 是否推送微信
PUSH_TO_WECHAT=true

# 邮箱接收人（可选）
EMAIL_RECIPIENT=

# 自动发布间隔（分钟）
INTERVAL_MINUTES=30
